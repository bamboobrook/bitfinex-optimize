# Copy to `.env` and fill in real values locally.
# Never commit `.env` (GitHub will flag exposed tokens/keys).

# Telegram notifications
TELEGRAM_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
TELEGRAM_TEST_MODE="False"

# Exchange / API credentials (example placeholders)
BA_API_KEY="YOUR_API_KEY"
BA_SECRET_KEY="YOUR_SECRET_KEY"
API_KEY="YOUR_API_KEY"
SECRET_KEY="YOUR_SECRET_KEY"

# Optional per-client overrides
# CLIENT_1_ID="1122334455"
# CLIENT_1_EMAIL="test01@example.com"
# CLIENT_1_API_KEY="YOUR_API_KEY"
# CLIENT_1_SECRET_KEY="YOUR_SECRET_KEY"
# CLIENT_1_TELEGRAM_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
# CLIENT_1_TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
# CLIENT_1_SHORT_RATIO="0.1"
# CLIENT_1_STATUS="active"
